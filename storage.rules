rules_version = '2';

// Chat attachments. Firestore caps a document at 1MB, which is why files
// used to be inlined as base64 there - that silently failed for anything
// much over ~700KB. Files now upload here instead, and the Firestore
// message just stores the resulting download URL.
//
// Kept simple on purpose: any signed-in user can read/write under these
// paths, with a server-side size cap matching the client-side one (so a
// tampered client can't bypass it). The actual "who can post a message"
// gate already lives in firestore.rules on the messages collection itself -
// an orphaned file with no matching message isn't a real exposure.
service firebase.storage {
  match /b/{bucket}/o {
    match /drives/{driveId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }
    match /dms/{dmId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
